<?xml version="1.0"?>
<Container version="2">
  <Name>mqtt-exporter</Name>
  <Repository>kpetrem/mqtt-exporter</Repository>
  <Registry>https://hub.docker.com/r/kpetrem/mqtt-exporter/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <MyMAC/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project>https://github.com/kpetremann/mqtt-exporter</Project>
  <ReadMe/>
  <Overview>Simple Prometheus exporter for MQTT</Overview>
  <Category>Network:Other</Category>
  <WebUI/>
  <TemplateURL>https://raw.githubusercontent.com/ccmpbll/unraid-docker-templates/refs/heads/master/templates/mqtt-exporter.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/ccmpbll/unraid-docker-templates/main/images/mqtt-exporter.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Port" Target="9000" Default="9000" Mode="tcp" Description="Port for Exporter" Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="MQTT_ADDRESS" Target="MQTT_ADDRESS" Default="" Mode="" Description="MQTT Broker IP" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="MQTT_TOPIC" Target="MQTT_TOPIC" Default="" Mode="" Description="MQTT Topics to monitor - comma separate multiple topics" Type="Variable" Display="always" Required="true" Mask="false"/>
</Container>
